# Anthropic API Key
# 발급: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Slack Bot Token (xoxb- 로 시작)
# 발급: https://api.slack.com/apps → 앱 선택 → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...

# Slack Signing Secret
# 발급: https://api.slack.com/apps → 앱 선택 → Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=...

# Tavily API Key
# 발급: https://tavily.com → Dashboard → API Keys
TAVILY_API_KEY=tvly-...

# Notion Integration Token (secret_ 로 시작)
# 발급: https://www.notion.so/my-integrations → New integration → Internal Integration Token
NOTION_TOKEN=secret_...

# Notion 기본 부모 페이지 ID (문서를 저장할 Notion 페이지의 ID)
# 페이지 URL 끝 32자리 (예: https://notion.so/workspace/페이지제목-<PAGE_ID>)
# 해당 페이지에 위에서 만든 Integration을 연결해야 합니다 (Share → Connections)
NOTION_PARENT_PAGE_ID=
